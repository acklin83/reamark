# ReaMark configuration — copy to .env and adjust.
# cp .env.example .env

# REQUIRED in production. Generate a strong random value:
#   openssl rand -hex 32
# If left at the default, JWT admin sessions are insecure.
REAMARK_SECRET_KEY=change-me-to-a-random-secret

# Optional: where the SQLite DB, uploads and waveform cache live inside the
# backend container. Defaults to /data (mounted from ./data via docker-compose).
# REAMARK_DATA_DIR=/data

# Only for docker-compose.caddy.yml (automatic HTTPS): the public hostname
# Caddy obtains a Let's Encrypt certificate for. DNS must point here and
# ports 80 + 443 must be reachable from the internet.
# REAMARK_DOMAIN=mix.example.com
